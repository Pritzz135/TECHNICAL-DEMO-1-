#include "mbed.h"

// --- Professional LED Class (from your example) ---
class LED {
protected:
    DigitalOut outputSignal;
    bool status;
public:
    // Application Shield LEDs are ACTIVE LOW
    // Constructor sets LED to OFF (1) initially
    LED(PinName pin) : outputSignal(pin) { off(); }

    void on(void) {
        outputSignal = 0; // 0 = ON for this shield
        status = true;
    }
    void off(void) {
        outputSignal = 1; // 1 = OFF for this shield
        status = false;
    }
};

// --- Hardware Configuration ---
// HM-10 on Morpho Pins: PA_11 (TX), PA_12 (RX)
Serial hm10(PA_11, PA_12); 

// Red component of the RGB LED on the Application Shield is D5
LED shieldRed(D5);

int main() {
    hm10.baud(9600);
    hm10.printf("Shield BLE System Online. Send 1 for Red ON, 0 for Red OFF\n");

    while(1) {
        if(hm10.readable()) {
            char command = hm10.getc();
            
            if(command == '1') {
                shieldRed.on();
                hm10.printf("Shield: Red LED ON\n");
            }
            else if(command == '0') {
                shieldRed.off();
                hm10.printf("Shield: Red LED OFF\n");
            }
        }
    }
}
